# Staging environment config — copy this file to .env.staging and fill in real values.
# .env.staging is gitignored; never commit it.
#
# Usage: npm run start:staging   (or android:staging / web:staging)
# See STAGING_SETUP.md for full local testing steps.

EXPO_PUBLIC_SUPABASE_URL=https://your-staging-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_staging_publishable_key

# Google OAuth — same client IDs as production unless staging needs its own.
# Native Google Sign-In (signInWithIdToken) is not tied to a specific Supabase
# project, so reusing production's client IDs is expected to work as-is.
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your_web_client_id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your_android_client_id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your_web_client_id.apps.googleusercontent.com
