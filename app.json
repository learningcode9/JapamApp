{
  "expo": {
    "name": "Mantra Japam",
    "slug": "JapamApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "description": "A mindful mantra counting app for daily Japam practice. Track your malas, set timers, and build a consistent spiritual practice.",
    "icon": "./assets/images/icon.png",
    "scheme": "japamapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0,
      "url": "https://u.expo.dev/17d71629-9516-49b8-8c90-863cc7e47027"
    },
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f5fafa"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.japamapp.mantrajapam"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "backgroundColor": "#f5fafa",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "package": "com.japamapp.mantrajapam",
      "versionCode": 4,
      "permissions": [
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "android.permission.WAKE_LOCK"
      ],
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.READ_CONTACTS",
        "android.permission.SYSTEM_ALERT_WINDOW",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECEIVE_BOOT_COMPLETED"
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./public/favicon-48.png",
      "name": "Mantra Japam",
      "shortName": "Mantra Japam",
      "themeColor": "#f5fafa",
      "backgroundColor": "#f5fafa"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#0F8F87",
          "androidMode": "default",
          "iosDisplayInForeground": true
        }
      ],
      "@react-native-google-signin/google-signin",
      "./plugins/withJapamTimerService"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "17d71629-9516-49b8-8c90-863cc7e47027"
      }
    },
    "owner": "learningcode9"
  }
}
