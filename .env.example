EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Google OAuth — Web client ID (used for web builds and Expo Go dev testing)
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your_web_client_id.apps.googleusercontent.com

# Google OAuth — Android client ID (required for native Android APK/AAB sign-in)
# Create at: console.cloud.google.com → APIs & Services → Credentials → Android OAuth client
# Package name: com.japamapp.mantrajapam
# SHA-1: obtain via `eas credentials --platform android`
# See: ANDROID_GOOGLE_SIGNIN_SETUP.md for full instructions
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your_android_client_id.apps.googleusercontent.com