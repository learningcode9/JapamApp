EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Google OAuth — Web client ID (used for web builds and Expo Go dev testing)
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your_web_client_id.apps.googleusercontent.com

# Google OAuth — Android client ID (required for native Android APK/AAB sign-in)
# Create at: console.cloud.google.com → APIs & Services → Credentials → Android OAuth client
# Package name: com.japamapp.mantrajapam
# SHA-1: obtain via `eas credentials --platform android`
# See: ANDROID_GOOGLE_SIGNIN_SETUP.md for full instructions
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your_android_client_id.apps.googleusercontent.com

# Email campaigns (see SUMMARY_EMAIL_SETUP.md and docs/CAMPAIGN_EMAIL_ARCHITECTURE.md)
# All optional — sensible defaults are used when unset. Secrets (RESEND_API_KEY,
# SUPABASE_SERVICE_ROLE_KEY) belong in .env.local, never here.
# EMAIL_FROM_ADDRESS=Japam App <noreply@yourdomain.com>
# EMAIL_SENDER_NAME=Japam App
# EMAIL_CTA_URL=https://mantra-japam.vercel.app
# EMAIL_LOGO_URL=
# EMAIL_HERO_IMAGE_URL=
# EMAIL_UNSUBSCRIBE_URL=
# EMAIL_COLOR_PRIMARY=#4B7F6B
# EMAIL_COLOR_PRIMARY_DARK=#365E4E
# EMAIL_COLOR_ACCENT=#E8A868
# EMAIL_COLOR_BACKGROUND=#F7F5F0
# EMAIL_COLOR_CARD=#FFFFFF
# EMAIL_COLOR_TEXT=#2E3B36
# EMAIL_COLOR_TEXT_MUTED=#6B7C76
# EMAIL_SOCIAL_LINKS=Instagram|https://instagram.com/example,Twitter|https://twitter.com/example
# PERIOD_DAYS=15