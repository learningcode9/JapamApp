{
    "buildCommand": "expo export -p web && node scripts/postprocess-web-html.js",
    "outputDirectory": "dist",
    "devCommand": "expo",
    "cleanUrls": true,
    "framework": null,
    "rewrites": [
      {
        "source": "/privacy",
        "destination": "/privacy.html"
      },
      {
        "source": "/delete-account",
        "destination": "/delete-account.html"
      },
      {
        "source": "/:path*",
        "destination": "/"
      }
    ]
  }
